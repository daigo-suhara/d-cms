/Users/daigo-suhara/Downloads/headless_cms_architecture.svg

headless-cms/
├── cmd/
│   └── server/
│       └── main.go              # エントリーポイント
├── config/
│   └── config.go                # 環境変数・設定読み込み
├── internal/
│   ├── domain/                  # ドメインモデル（純粋なGoの型定義）
│   │   ├── article.go
│   │   ├── media.go
│   │   └── errors.go
│   ├── repository/              # DBアクセス層（interfaceと実装）
│   │   ├── interface.go         # ArticleRepository interface
│   │   ├── article_repository.go
│   │   └── media_repository.go
│   ├── service/                 # ビジネスロジック層
│   │   ├── article_service.go
│   │   └── media_service.go
│   ├── controller/              # HTTPハンドラ（入力検証・ルーティング）
│   │   ├── article_controller.go
│   │   └── media_controller.go
│   ├── presenter/               # ★ レスポンス形式の分岐ここに集約
│   │   ├── presenter.go         # interface + Respond() ヘルパー
│   │   ├── html_presenter.go    # HTMX用テンプレートレンダリング
│   │   └── json_presenter.go    # JSON シリアライズ
│   ├── middleware/
│   │   ├── auth.go
│   │   └── request_id.go
│   └── infrastructure/
│       ├── database/
│       │   └── postgres.go      # GORM接続
│       └── storage/
│           └── r2_client.go     # S3 SDK v2 ラッパー
├── templates/                   # HTMLテンプレート（HTMX用）
│   ├── layout/
│   │   └── base.html
│   └── articles/
│       ├── list.html
│       └── detail.html
├── router/
│   └── router.go                # Ginルーティング定義
├── .env.example
├── go.mod
└── go.sum
